# Supabase settings (uncomment and configure to use Supabase)
SUPABASE_URL="your_supabase_url_here"
SUPABASE_KEY=your_supabase_key_here

# Supabase storage settings (for file storage operations)
SUPABASE_URL_STORAGE="your_supabase_storage_url_here"
SUPABASE_KEY_STORAGE="your_supabase_storage_key_here"
SUPABASE_BUCKET_STORAGE="your_storage_bucket_name_here"

# Image generation API keys
BFL_API_KEY="your_flux_api_key_here"
OPENAI_ORGANIZATION_ID="your_openai_organization_id_here"

# LLM keys
OPENAI_API_KEY=your_openai_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Access control
EAX_ACCESS_TOKEN=your_secret_access_token_here_change_this